{
  "name": "vast",
  "version": "0.0.0",
  "private": true,
  "description": "Vast — a modern, unified business suite. No limits.",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @vast/db generate",
    "db:migrate": "pnpm --filter @vast/db migrate"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "prisma", "@prisma/engines", "esbuild", "sharp"]
  }
}
