# Copy to .env and fill in. NEVER commit the real .env.

# --- Database (Supabase / local Postgres) ---
DATABASE_URL="postgresql://vast:vast@localhost:5432/vast?schema=public"

# --- Redis (local / Upstash) ---
REDIS_URL="redis://localhost:6379"

# --- API ---
API_PORT=4000
NODE_ENV=development

# CORS: comma-separated allowlist of origins permitted to call the API
CORS_ALLOWED_ORIGINS="http://localhost:3000"

# --- Web ---
NEXT_PUBLIC_API_URL="http://localhost:4000"

# --- Auth (Supabase) — fill when wiring auth ---
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
