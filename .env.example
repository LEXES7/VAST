# Copy to .env and fill in. NEVER commit the real .env.

# --- Database (Supabase / local Postgres) ---
DATABASE_URL="postgresql://vast:vast@localhost:5432/vast?schema=public"

# --- Redis (local / Upstash) ---
REDIS_URL="redis://localhost:6379"

# --- API ---
API_PORT=4000
NODE_ENV=development

# CORS: comma-separated allowlist of origins permitted to call the API
CORS_ALLOWED_ORIGINS="http://localhost:3000"

# --- Web ---
NEXT_PUBLIC_API_URL="http://localhost:4000"

# --- Auth (Supabase) ---
# API verifies JWTs against this project's public JWKS (no secret needed).
SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"

# Frontend (apps/web/.env.local) uses the public values:
#   NEXT_PUBLIC_SUPABASE_URL=...
#   NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=...
